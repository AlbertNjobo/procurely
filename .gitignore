# ==============================================================================
# Dependencies
# ==============================================================================
# Dependency directories should not be checked into git because they can be
# restored anytime using package managers (e.g., `npm install`).
node_modules/
jspm_packages/
web_modules/

# ==============================================================================
# Production / Build Outputs
# ==============================================================================
# Output directory generated by build commands (e.g., `npm run build` or Vite).
dist/
build/
out/

# ==============================================================================
# Environment Variables and Secrets (CRITICAL FOR SECURITY)
# ==============================================================================
# Ignore all environment files containing API keys, database URLs, and secrets.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# BUT track the example environment file so team members know what variables are needed.
!.env.example

# ==============================================================================
# Firebase-specific
# ==============================================================================
# Firebase CLI cache/hosting deploy artifacts, configs, and debug logs.
.firebase/
firebase-debug.log
ui-debug.log
# Firebase web client config is gitignored: it holds a public web API key, but we
# keep it out of git to avoid GitHub secret-scanning alerts. For cloning, the app
# falls back to firebase-applet-config.example.json; for local/deploy, copy:
#   cp firebase-applet-config.example.json firebase-applet-config.json
firebase-applet-config.json
# Never commit service-account JSON or GOOGLE_APPLICATION_CREDENTIALS files.
*-firebase-adminsdk-*.json
service-account*.json

# ==============================================================================
# TypeScript
# ==============================================================================
# Compilation info/caches for TypeScript.
*.tsbuildinfo

# ==============================================================================
# IDEs and Editors
# ==============================================================================
# VS Code local workspace configurations (except shared extensions/tasks)
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ IDEA, PyCharm, etc.)
.idea/

# Eclipse
.project
.classpath
.settings/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim swap/temporary files
*.swp
*.swo
*~

# ==============================================================================
# System Files
# ==============================================================================
# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# ==============================================================================
# Logs and Diagnostics
# ==============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==============================================================================
# Local Scratch / Test Scripts
# ==============================================================================
test-firestore*
test_asr.js

# Patch scripts (changes already applied to source)
patch_*.cjs

# Firebase service account key
service-account.json

.aidesigner/*
!.aidesigner/.gitkeep

## Agents file 
.claude/
.agents/
.mimocode/
data/
.kimchi/
archify/

# Generated architecture files
architecture.architecture.json

# IDE-specific
assets/.aistudio/

# Image exports from docs
docs/procurely-ai-procurement-agent*

# Compose skill output
docs/compose/
